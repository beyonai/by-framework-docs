# Worker 基础配置
BYAI_WORKER_ID=langgraph-worker-1
BYAI_WORKSPACE_DIR=/tmp/gateway-workspace

# Redis 连接配置
BYAI_REDIS_HOST=127.0.0.1
BYAI_REDIS_PORT=6379
BYAI_REDIS_DB=0
BYAI_REDIS_PASSWORD=
BYAI_REDIS_USERNAME=

# LLM 配置 (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

