# Redis 连接配置
BYAI_REDIS_HOST=127.0.0.1
BYAI_REDIS_PORT=6379
BYAI_REDIS_DB=0
# BYAI_REDIS_PASSWORD=
# BYAI_REDIS_USERNAME=

# Worker 配置
BYAI_WORKER_ID=claude-agent-worker-1

# Claude Agent 配置
# Claude Agent SDK 的工作目录（Claude Code 在此目录下执行文件读写和命令操作）
CLAUDE_AGENT_CWD=.

# Claude Agent 最大交互轮次（默认 200）
CLAUDE_MAX_TURNS=200

# 可选：指定 Claude CLI 路径（SDK 默认自带，通常无需配置）
# CLAUDE_CLI_PATH=/path/to/claude

# 可选：自定义 system prompt
# CLAUDE_SYSTEM_PROMPT=You are a helpful coding assistant.
