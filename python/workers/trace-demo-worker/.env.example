# Worker 基础配置
BYAI_WORKER_ID=trace-demo-worker-1
BYAI_WORKSPACE_DIR=/tmp/gateway-workspace

# Redis 连接配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here
REDIS_USERNAME=default

# Langfuse 链路追踪配置（若使用）
LANGFUSE_SECRET_KEY="sk-lf-your-secret-key-here"
LANGFUSE_PUBLIC_KEY="pk-lf-your-public-key-here"
LANGFUSE_BASE_URL="http://localhost:3000"

# Arize Phoenix 链路追踪配置（若使用）
BYAI_PHOENIX_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006/v1/traces"
PHOENIX_PROJECT_NAME="by-framework"

BY_FRAMEWORK_OTEL_ENABLED=true
BY_FRAMEWORK_LANGFUSE_ENABLED=true
